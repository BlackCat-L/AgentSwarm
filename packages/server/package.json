{
  "name": "@agent-swarm/server",
  "version": "0.0.0",
  "private": true,
  "description": "Agent Swarm HTTP 服务器 (Hono)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "predev": "pnpm --filter @agent-swarm/shared build",
    "dev": "tsx watch src/index.ts",
    "dev:stable": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-swarm/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@hono/node-server": "^2.0.4",
    "hono": "^4.7.0",
    "jose": "^6.2.3",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
